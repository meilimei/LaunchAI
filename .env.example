# ============================================================
# LaunchAI 环境变量模板
# 复制到 .env.local(开发)或 .env.production(生产)
# ============================================================

# ---------- 应用 ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------- 数据库(Postgres) ----------
# 推荐:Supabase Free(零安装、生产同栈、$0/月)
#   1. https://supabase.com 创建免费项目
#   2. Settings → Database → Connection string
#   3. DATABASE_URL  使用 "Transaction pooler"(端口 6543) — 给 app 运行时用
#      DIRECT_URL    使用 "Direct connection" 或 "Session pooler"(端口 5432) — 给 drizzle-kit 迁移用
#   ⚠ pooler 6543 不支持 DDL,所以迁移必须走 5432
#
# 备选:本地 Docker(需 Docker Desktop / Podman / Rancher)
#   DATABASE_URL=postgres://launchai:launchai@localhost:5432/launchai
#   DIRECT_URL=postgres://launchai:launchai@localhost:5432/launchai
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# ---------- 队列 / 缓存(Redis) ----------
# 推荐:Upstash Free(零安装、生产同栈、$0/月)
#   1. https://upstash.com 创建免费 Redis 数据库
#   2. 选 region(就近)→ 复制 "Redis URL"(rediss:// 开头,带 TLS)
#
# 备选:本地 Docker
#   REDIS_URL=redis://localhost:6379
REDIS_URL=rediss://default:<token>@<region>.upstash.io:6379

# ---------- LLM Providers ----------
# 推荐:DEEPSEEK_API_KEY(所有 agent 默认走 deepseek-v4-pro,1M 上下文 + thinking
# mode 默认开启 + reasoning_effort=high,比 gpt-4o 便宜、比 Sonnet 便宜,质量
# 追平 Sonnet 4.5)。https://api-docs.deepseek.com/news/news260424
#
# 配置一组即可(优先级:DeepSeek > OpenAI+Anthropic > 仅 OpenAI):
#   - DEEPSEEK_API_KEY 配置 → 所有 role 默认 deepseek-v4-pro,Free 套餐 writer 走 v4-flash
#   - OPENAI_API_KEY + ANTHROPIC_API_KEY → gpt-4o-mini 提取 + Sonnet 写文案
#   - 仅 OPENAI_API_KEY → 全部 gpt-4o-mini
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 可选:模型路由覆盖(默认见 src/lib/llm/config.ts)
# 可用 keys:deepseek-v4-pro / deepseek-v4-flash / gpt-4o-mini / gpt-4o /
#           claude-sonnet-4-5 / deepseek-chat(legacy) / deepseek-reasoner(legacy)
# LLM_ANALYST_MODEL=deepseek-v4-pro
# LLM_WRITER_MODEL=deepseek-v4-pro
# LLM_CRITIC_MODEL=deepseek-v4-pro

# ---------- 抓取 ----------
# 生产环境:Browserbase API key
# 开发环境留空,使用本地 Playwright
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ---------- Auth(Clerk) ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ---------- Payment(Stripe) ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs(在 Stripe Dashboard 创建后填入)
STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# ---------- 监控(可选) ----------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- 邮件(发布提醒,v1.1) ----------
RESEND_API_KEY=
EMAIL_FROM=launch@launchai.app
