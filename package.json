{
  "name": "launchai",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous AI agent for Chrome extension developers' launch marketing",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "dev:worker": "dotenv -e .env.local -- tsx watch src/worker/index.ts",
    "dev:all": "concurrently -n web,worker -c blue,magenta \"pnpm dev\" \"pnpm dev:worker\"",
    "dev:enqueue": "dotenv -e .env.local -- tsx scripts/dev-enqueue.ts",
    "diag:redis": "dotenv -e .env.local -- tsx scripts/diag-redis.ts",
    "diag:queue": "dotenv -e .env.local -- tsx scripts/diag-queue.ts",
    "diag:db": "dotenv -e .env.local -- tsx scripts/diag-db.ts",
    "connect:account": "dotenv -e .env.local -- tsx scripts/connect-account.ts",
    "browser:check": "dotenv -e .env.local -- tsx scripts/browser-check.ts",
    "dev:mosaiq-smoke": "dotenv -e .env.local -- tsx scripts/dev-mosaiq-smoke.ts",
    "dev:run-action": "dotenv -e .env.local -- tsx scripts/dev-run-action.ts",
    "dev:warmup": "dotenv -e .env.local -- tsx scripts/dev-warmup.ts",
    "dev:strategy": "dotenv -e .env.local -- tsx scripts/dev-strategy.ts",
    "dev:selectors": "dotenv -e .env.local -- tsx scripts/dev-selectors.ts",
    "dev:clear-cooldown": "dotenv -e .env.local -- tsx scripts/dev-clear-cooldown.ts",
    "dump:job": "dotenv -e .env.local -- tsx scripts/dump-job.ts",
    "build": "next build",
    "start": "next start",
    "start:worker": "tsx src/worker/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:apply": "dotenv -e .env.local -- tsx scripts/db-apply.ts",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/deepseek": "^0.2.16",
    "@ai-sdk/openai": "^1.1.0",
    "@clerk/nextjs": "^6.10.0",
    "@hookform/resolvers": "^3.10.0",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.62.0",
    "ai": "^4.1.0",
    "bullmq": "^5.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.2",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "next": "^15.5.0",
    "p-retry": "^6.2.1",
    "playwright": "^1.49.1",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "stripe": "^17.5.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "playwright-core": "1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0"
}
